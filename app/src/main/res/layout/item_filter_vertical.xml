<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/filterContainer"
    android:layout_width="96dp"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/filter_item_background">

    <FrameLayout
        android:id="@+id/filterThumbCard"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/preset_thumb_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/filterThumbnail"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            android:clipToOutline="true"
            android:foreground="?attr/selectableItemBackgroundBorderless" />
    </FrameLayout>

    <TextView
        android:id="@+id/filterName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:padding="6dp"
        android:background="@drawable/filter_name_bg"
        android:textSize="12sp"
        android:textColor="@color/grey_dark"
        app:layout_constraintTop_toBottomOf="@+id/filterThumbCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

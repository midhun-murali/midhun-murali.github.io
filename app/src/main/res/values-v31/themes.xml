<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen attributes to suppress the centered icon and use our window background -->
    <style name="Theme.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_window_background</item>
        <!-- Use a tiny transparent icon so system won't display the app icon in center -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/transparent_splash_icon</item>
        <!-- Make icon background transparent (no colored circle) -->
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <!-- Disable animation duration so no animation is shown -->
        <item name="android:windowSplashScreenAnimationDuration">0</item>
        <!-- Ensure the splash background uses our drawable (fallback) -->
        <item name="android:windowSplashScreenBackground">@android:color/transparent</item>
    </style>
</resources>

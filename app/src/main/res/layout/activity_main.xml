<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toBottomOf="@+id/topBar"
        app:layout_constraintBottom_toTopOf="@+id/filterCarousel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Countdown overlay for timer -->
    <TextView
        android:id="@+id/countdownOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="72sp"
        android:textColor="@color/white"
        android:visibility="gone"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="6"
        app:layout_constraintTop_toTopOf="@+id/previewView"
        app:layout_constraintBottom_toBottomOf="@+id/previewView"
        app:layout_constraintStart_toStartOf="@+id/previewView"
        app:layout_constraintEnd_toEndOf="@+id/previewView"
        android:gravity="center" />

    <!-- Gallery image overlay (hidden by default) -->
    <ImageView
        android:id="@+id/galleryImageOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="@string/preview_image"
        app:layout_constraintTop_toBottomOf="@+id/topBar"
        app:layout_constraintBottom_toTopOf="@+id/filterCarousel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Close button for gallery overlay -->
    <ImageButton
        android:id="@+id/closeGalleryButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/close"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@+id/topBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        app:tint="@color/white" />

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@drawable/top_bar_background"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Settings Icon -->
        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/app_name"
            android:padding="4dp" />

        <!-- HDR Text (toggle) -->
        <TextView
            android:id="@+id/hdrButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hdr"
            android:textColor="@color/grey_dark"
            android:textSize="14sp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Flash Icon -->
        <ImageButton
            android:id="@+id/flashButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_flash"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/flash"
            android:padding="4dp"
            android:layout_marginStart="16dp" />

        <!-- Timer Icon with Text (toggle) -->
        <LinearLayout
            android:id="@+id/timerButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="16dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_timer"
                android:contentDescription="@string/timer_3s"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/timerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timer_3s"
                android:textColor="@color/grey_dark"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Camera Switch Icon -->
        <ImageButton
            android:id="@+id/cameraSwitchButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera_switch"
            android:background="@drawable/shutter_button_outer"
            android:contentDescription="@string/switch_camera"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Filter Carousel -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/filterCarousel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Control Bar -->
    <RelativeLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@drawable/bottom_bar_background"
        android:gravity="center_vertical"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gallery Button -->
        <ImageButton
            android:id="@+id/galleryButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_gallery"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/gallery"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:padding="8dp" />

        <!-- Shutter Button Container -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true">

            <!-- Outer Ring -->
            <ImageView
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:src="@drawable/shutter_button_outer"
                android:contentDescription="@string/capture_photo"
                android:layout_gravity="center" />

            <!-- Inner Button -->
            <ImageButton
                android:id="@+id/captureButton"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/shutter_button_background"
                android:contentDescription="@string/capture_photo"
                android:layout_gravity="center"
                android:elevation="4dp" />
        </FrameLayout>
    </RelativeLayout>

    <!-- AdView (hidden for now, can be added back if needed) -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:adSize="BANNER"
        app:adUnitId="@string/admob_banner_id"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
